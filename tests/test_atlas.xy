# pylint: disable=missing-module-docstring,missing-class-docstring,missing-function-docstring
from unittest.mock import MagicMock, patch, call
import unittest

from jirabatch.atlas import Atlas


class TestBuildFields(unittest.TestCase):
    """Tests for Atlas._build_fields static method."""

    def test_required_fields_only(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "Minimal task",
        }
        result = Atlas._build_fields(issue)
        assert result == {
            "project": {"key": "ENG"},
            "issuetype": {"name": "Task"},
            "summary": "Minimal task",
            "description": None,
        }

    def test_description(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "description": "Some details",
        }
        result = Atlas._build_fields(issue)
        assert result["description"] == "Some details"

    def test_reporter(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "reporter": "tech-lead",
        }
        result = Atlas._build_fields(issue)
        assert result["reporter"] == {"name": "tech-lead"}

    def test_assignee(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "assignee": "cliffano",
        }
        result = Atlas._build_fields(issue)
        assert result["assignee"] == {"name": "cliffano"}

    def test_priority(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "priority": "High",
        }
        result = Atlas._build_fields(issue)
        assert result["priority"] == {"name": "High"}

    def test_labels(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "labels": ["infra", "aws"],
        }
        result = Atlas._build_fields(issue)
        assert result["labels"] == ["infra", "aws"]

    def test_components(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "components": ["Cloud", "Backend"],
        }
        result = Atlas._build_fields(issue)
        assert result["components"] == [{"name": "Cloud"}, {"name": "Backend"}]

    def test_versions(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "versions": ["2025.4"],
        }
        result = Atlas._build_fields(issue)
        assert result["versions"] == [{"name": "2025.4"}]

    def test_fix_versions(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "fixVersions": ["2026.1", "2026.2"],
        }
        result = Atlas._build_fields(issue)
        assert result["fixVersions"] == [{"name": "2026.1"}, {"name": "2026.2"}]

    def test_environment(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "environment": "Production AWS us-east-1",
        }
        result = Atlas._build_fields(issue)
        assert result["environment"] == "Production AWS us-east-1"

    def test_due_date(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "dueDate": "2026-04-01",
        }
        result = Atlas._build_fields(issue)
        assert result["duedate"] == "2026-04-01"
        assert "dueDate" not in result

    def test_timetracking(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "timetracking": {
                "originalEstimate": "3d",
                "remainingEstimate": "3d",
            },
        }
        result = Atlas._build_fields(issue)
        assert result["timetracking"] == {
            "originalEstimate": "3d",
            "remainingEstimate": "3d",
        }

    def test_security(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "security": "Confidential",
        }
        result = Atlas._build_fields(issue)
        assert result["security"] == {"name": "Confidential"}

    def test_parent(self):
        issue = {
            "project": "ENG",
            "issuetype": "Sub-task",
            "summary": "A sub-task",
            "parent": "ENG-100",
        }
        result = Atlas._build_fields(issue)
        assert result["parent"] == {"key": "ENG-100"}

    def test_custom_fields_team_and_sprint(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "customFields": {
                "customfield_10100": "Platform Team",
                "customfield_10200": "Sprint 42",
            },
        }
        result = Atlas._build_fields(issue)
        assert result["customfield_10100"] == "Platform Team"
        assert result["customfield_10200"] == "Sprint 42"

    def test_custom_fields_do_not_overwrite_standard_fields(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "A task",
            "priority": "High",
            "customFields": {
                "customfield_10100": "Security Team",
            },
        }
        result = Atlas._build_fields(issue)
        assert result["priority"] == {"name": "High"}
        assert result["customfield_10100"] == "Security Team"

    def test_all_fields_together(self):
        issue = {
            "project": "ENG",
            "issuetype": "Task",
            "summary": "Full task",
            "description": "All fields set",
            "reporter": "tech-lead",
            "assignee": "cliffano",
            "priority": "High",
            "labels": ["infra"],
            "components": ["Cloud"],
            "versions": ["2025.4"],
            "fixVersions": ["2026.1"],
            "environment": "Production",
            "dueDate": "2026-04-01",
            "timetracking": {"originalEstimate": "5d"},
            "security": "Internal",
            "parent": "ENG-50",
            "customFields": {
                "customfield_10100": "Platform Team",
                "customfield_10200": "Sprint 42",
            },
        }
        result = Atlas._build_fields(issue)
        assert result["project"] == {"key": "ENG"}
        assert result["issuetype"] == {"name": "Task"}
        assert result["summary"] == "Full task"
        assert result["description"] == "All fields set"
        assert result["reporter"] == {"name": "tech-lead"}
        assert result["assignee"] == {"name": "cliffano"}
        assert result["priority"] == {"name": "High"}
        assert result["labels"] == ["infra"]
        assert result["components"] == [{"name": "Cloud"}]
        assert result["versions"] == [{"name": "2025.4"}]
        assert result["fixVersions"] == [{"name": "2026.1"}]
        assert result["environment"] == "Production"
        assert result["duedate"] == "2026-04-01"
        assert result["timetracking"] == {"originalEstimate": "5d"}
        assert result["security"] == {"name": "Internal"}
        assert result["parent"] == {"key": "ENG-50"}
        assert result["customfield_10100"] == "Platform Team"
        assert result["customfield_10200"] == "Sprint 42"


class TestCreateJiraIssues(unittest.TestCase):
    """Tests for Atlas.create_jira_issues method."""

    @patch("jirabatch.atlas.JIRA")
    @patch("jirabatch.atlas.init")
    def test_single_issue_success(self, mock_init, mock_jira_cls):
        mock_logger = MagicMock()
        mock_init.return_value = mock_logger

        mock_created = MagicMock()
        mock_created.key = "ENG-1"
        mock_created.fields.summary = "A task"

        mock_jira = MagicMock()
        mock_jira_cls.return_value = mock_jira
        mock_jira.create_issues.return_value = [
            {
                "status": "Success",
                "issue": mock_created,
                "input_fields": {"summary": "A task"},
            }
        ]

        conf = {"url": "https://jira.example.com", "user": "u", "api_token": "t"}
        atlas = Atlas(conf)

        issues = {
            "issues": [{"project": "ENG", "issuetype": "Task", "summary": "A task"}]
        }
        atlas.create_jira_issues(issues)

        mock_jira.create_issues.assert_called_once()
        mock_logger.info.assert_called_once_with(
            "Created issue %s: %s", "ENG-1", "A task"
        )

    @patch("jirabatch.atlas.JIRA")
    @patch("jirabatch.atlas.init")
    def test_issue_failure_logs_error(self, mock_init, mock_jira_cls):
        mock_logger = MagicMock()
        mock_init.return_value = mock_logger

        mock_jira = MagicMock()
        mock_jira_cls.return_value = mock_jira
        mock_jira.create_issues.return_value = [
            {
                "status": "Error",
                "error": "Field 'summary' is required",
                "input_fields": {"project": {"key": "ENG"}},
            }
        ]

        conf = {"url": "https://jira.example.com", "user": "u", "api_token": "t"}
        atlas = Atlas(conf)

        issues = {
            "issues": [{"project": "ENG", "issuetype": "Task", "summary": "Bad issue"}]
        }
        atlas.create_jira_issues(issues)

        mock_logger.error.assert_called_once()
        assert "Field 'summary' is required" in mock_logger.error.call_args[0][1]

    @patch("jirabatch.atlas.JIRA")
    @patch("jirabatch.atlas.init")
    def test_batching_over_max_batch_size(self, mock_init, mock_jira_cls):
        mock_logger = MagicMock()
        mock_init.return_value = mock_logger

        mock_jira = MagicMock()
        mock_jira_cls.return_value = mock_jira

        def make_result(i):
            mock_issue = MagicMock()
            mock_issue.key = f"ENG-{i}"
            mock_issue.fields.summary = f"Task {i}"
            return {
                "status": "Success",
                "issue": mock_issue,
                "input_fields": {"summary": f"Task {i}"},
            }

        # 75 issues with default batch_size=50 should produce 2 batches: 50 + 25
        num_issues = 75
        mock_jira.create_issues.side_effect = [
            [make_result(i) for i in range(50)],
            [make_result(i) for i in range(50, 75)],
        ]

        conf = {"url": "https://jira.example.com", "user": "u", "api_token": "t"}
        atlas = Atlas(conf)

        issues = {
            "issues": [
                {"project": "ENG", "issuetype": "Task", "summary": f"Task {i}"}
                for i in range(num_issues)
            ]
        }
        atlas.create_jira_issues(issues)

        assert mock_jira.create_issues.call_count == 2
        first_batch = mock_jira.create_issues.call_args_list[0]
        second_batch = mock_jira.create_issues.call_args_list[1]
        assert len(first_batch.kwargs["field_list"]) == 50
        assert len(second_batch.kwargs["field_list"]) == 25

    @patch("jirabatch.atlas.JIRA")
    @patch("jirabatch.atlas.init")
    def test_batching_with_custom_batch_size(self, mock_init, mock_jira_cls):
        mock_logger = MagicMock()
        mock_init.return_value = mock_logger

        mock_jira = MagicMock()
        mock_jira_cls.return_value = mock_jira

        def make_result(i):
            mock_issue = MagicMock()
            mock_issue.key = f"ENG-{i}"
            mock_issue.fields.summary = f"Task {i}"
            return {
                "status": "Success",
                "issue": mock_issue,
                "input_fields": {"summary": f"Task {i}"},
            }

        # 5 issues with batch_size=2 should produce 3 batches: 2 + 2 + 1
        num_issues = 5
        mock_jira.create_issues.side_effect = [
            [make_result(i) for i in range(2)],
            [make_result(i) for i in range(2, 4)],
            [make_result(i) for i in range(4, 5)],
        ]

        conf = {"url": "https://jira.example.com", "user": "u", "api_token": "t"}
        atlas = Atlas(conf)

        issues = {
            "issues": [
                {"project": "ENG", "issuetype": "Task", "summary": f"Task {i}"}
                for i in range(num_issues)
            ]
        }
        atlas.create_jira_issues(issues, batch_size=2)

        assert mock_jira.create_issues.call_count == 3
        assert len(mock_jira.create_issues.call_args_list[0].kwargs["field_list"]) == 2
        assert len(mock_jira.create_issues.call_args_list[1].kwargs["field_list"]) == 2
        assert len(mock_jira.create_issues.call_args_list[2].kwargs["field_list"]) == 1

    @patch("jirabatch.atlas.JIRA")
    @patch("jirabatch.atlas.init")
    def test_mixed_success_and_failure(self, mock_init, mock_jira_cls):
        mock_logger = MagicMock()
        mock_init.return_value = mock_logger

        mock_created = MagicMock()
        mock_created.key = "ENG-1"
        mock_created.fields.summary = "Good task"

        mock_jira = MagicMock()
        mock_jira_cls.return_value = mock_jira
        mock_jira.create_issues.return_value = [
            {
                "status": "Success",
                "issue": mock_created,
                "input_fields": {"summary": "Good task"},
            },
            {
                "status": "Error",
                "error": "Permission denied",
                "input_fields": {"summary": "Bad task"},
            },
        ]

        conf = {"url": "https://jira.example.com", "user": "u", "api_token": "t"}
        atlas = Atlas(conf)

        issues = {
            "issues": [
                {"project": "ENG", "issuetype": "Task", "summary": "Good task"},
                {"project": "ENG", "issuetype": "Task", "summary": "Bad task"},
            ]
        }
        atlas.create_jira_issues(issues)

        mock_logger.info.assert_called_once()
        mock_logger.error.assert_called_once()

    @patch("jirabatch.atlas.JIRA")
    @patch("jirabatch.atlas.init")
    def test_custom_fields_passed_through(self, mock_init, mock_jira_cls):
        mock_logger = MagicMock()
        mock_init.return_value = mock_logger

        mock_created = MagicMock()
        mock_created.key = "ENG-1"
        mock_created.fields.summary = "A task"

        mock_jira = MagicMock()
        mock_jira_cls.return_value = mock_jira
        mock_jira.create_issues.return_value = [
            {
                "status": "Success",
                "issue": mock_created,
                "input_fields": {},
            }
        ]

        conf = {"url": "https://jira.example.com", "user": "u", "api_token": "t"}
        atlas = Atlas(conf)

        issues = {
            "issues": [
                {
                    "project": "ENG",
                    "issuetype": "Task",
                    "summary": "A task",
                    "customFields": {
                        "customfield_10100": "Platform Team",
                        "customfield_10200": "Sprint 42",
                    },
                }
            ]
        }
        atlas.create_jira_issues(issues)

        sent_fields = mock_jira.create_issues.call_args.kwargs["field_list"][0]
        assert sent_fields["customfield_10100"] == "Platform Team"
        assert sent_fields["customfield_10200"] == "Sprint 42"
